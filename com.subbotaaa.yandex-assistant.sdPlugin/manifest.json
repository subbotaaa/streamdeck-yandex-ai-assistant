{
	"$schema": "https://schemas.elgato.com/streamdeck/plugins/manifest.json",
	"Name": "Yandex AI Assistant",
	"UUID": "com.subbotaaa.yandex-assistant",
	"Version": "1.0.0.0",
	"Author": "subbotaaa",
	"URL": "https://github.com/subbotaaa/streamdeck-yandex-ai-assistant",
	"Description": "Push-to-talk AI voice assistant powered by Yandex Cloud: hold the key and speak — get an answer from YandexGPT, Alice AI, Qwen or DeepSeek as voice or text. Russian and English UI.",
	"Category": "Yandex AI Assistant",
	"CategoryIcon": "imgs/category",
	"Icon": "imgs/plugin",
	"CodePath": "bin/plugin.js",
	"SDKVersion": 3,
	"Nodejs": {
		"Version": "20"
	},
	"Software": {
		"MinimumVersion": "6.9"
	},
	"OS": [
		{
			"Platform": "windows",
			"MinimumVersion": "10"
		}
	],
	"Actions": [
		{
			"Name": "Voice Assistant",
			"UUID": "com.subbotaaa.yandex-assistant.ask",
			"Icon": "imgs/action",
			"Tooltip": "Hold the key and speak. Release to get an AI answer as voice or text.",
			"PropertyInspectorPath": "ui/pi.html",
			"Controllers": [
				"Keypad"
			],
			"SupportedInMultiActions": false,
			"UserTitleEnabled": false,
			"States": [
				{
					"Image": "imgs/action",
					"TitleAlignment": "bottom"
				}
			]
		}
	]
}